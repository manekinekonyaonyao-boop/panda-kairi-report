    if (min === max) { min *= 0.99; max *= 1.01; }
    const pad = (max - min) * 0.08;
    min -= pad; max += pad;
    const denom = max - min || 1;
    const path = points.map(function (p, i) {
      const x = m + (w - 2 * m) * i / (points.length - 1);
      const y = h - m - (p.value - min) / denom * (h - 2 * m);
